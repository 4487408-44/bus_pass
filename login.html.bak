<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bus Pass System - Login</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div class="container">
        <div class="form-container">
            <h2>Welcome Back</h2>
            <p>Please enter your details to continue.</p>
            
            <div id="message" class="message hidden"></div>

            <form id="authForm">
                <div class="input-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" required placeholder="Enter your email">
                </div>
                <div class="input-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" required placeholder="••••••••">
                </div>
                
                <button type="submit" id="loginBtn" class="btn primary-btn">Login</button>
                <button type="button" id="registerBtn" class="btn secondary-btn">Register New User</button>
            </form>
        </div>
    </div>

    <script>
        const form = document.getElementById('authForm');
        const msgDiv = document.getElementById('message');

        function showMessage(msg, isError = false) {
            msgDiv.textContent = msg;
            msgDiv.className = `message ${isError ? 'error' : 'success'}`;
        }

        async function submitAuth(path) {
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;

            if (!email || !password) {
                alert('Please fill in both fields.');
                return;
            }

            try {
                const response = await fetch(path, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, password })
                });

                const data = await response.json();
                
                if (response.ok) {
						if (path.includes('login'))					{
                        // 1. Save user_id to identify them
                        localStorage.setItem('user_id', data.user_id);
                        localStorage.setItem('username', email.split('@')[0]);
                        
                        // 2. Clear out any old passes from the previous user's login
                        localStorage.removeItem('monthlyPassType');
                        localStorage.removeItem('monthlyPassEnd');
                        localStorage.removeItem('monthlyPassRoute');
                        localStorage.removeItem('monthlyPassName');
                        localStorage.removeItem('dailyPassType');
                        localStorage.removeItem('dailyPassEnd');
                        localStorage.removeItem('dailyPassRoute');
                        localStorage.removeItem('dailyPassName');
                        
                        alert('Login successful! Fetching your passes...');
                        
                        // 3. Download their passes from the database
                        try {
                            const passRes = await fetch('http://localhost:8082/get_passes', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ user_id: data.user_id })
                            });
                            if (passRes.ok) {
                     
								
								const passData = await passRes.json();

// ✅ ADD THIS LINE
console.log("PASS DATA:", passData);
								
								
                                if (passData.passes) {
                                    passData.passes.forEach(p => {

    if (p.pass_type.toLowerCase() === 'daily') {

        localStorage.setItem('dailyPassType', p.pass_type);
        localStorage.setItem('dailyPassEnd', p.expiry_date);
        localStorage.setItem('dailyPassRoute', p.bus_number);

    } else {

        localStorage.setItem('monthlyPassType', p.pass_type);
        localStorage.setItem('monthlyPassEnd', p.expiry_date);
        localStorage.setItem('monthlyPassRoute', p.bus_number);
    }

});

										
										{
										if (p.type.toLowerCase() === 'daily') {
    localStorage.setItem('dailyPassType', p.type);
    localStorage.setItem('dailyPassEnd', p.expiry_date);
    localStorage.setItem('dailyPassRoute', p.bus);
    localStorage.setItem('dailyPassName', localStorage.getItem('username'));
} else {
    localStorage.setItem('monthlyPassType', p.type);
    localStorage.setItem('monthlyPassEnd', p.expiry_date);
    localStorage.setItem('monthlyPassRoute', p.bus);
    localStorage.setItem('monthlyPassName', localStorage.getItem('username'));
}
                                    });
                                }
                            }
                        } catch(e) {
                            console.error('Could not download passes from database:', e);
                        }

                        window.location.href = '/dashboard.html';
                    } else {
                        alert("User registered successfully! You can now login.");
                    }
                } else {
                    if (data.error === "User already exists!") {
                        alert("User already registered. Please Login.");
                    } else {
                        alert(data.error || 'An error occurred');
                    }
                }
            } catch (err) {
                alert('Failed to connect to server.');
            }
        }

        document.getElementById('loginBtn').addEventListener('click', (e) => {
            e.preventDefault();
			submitAuth('http://localhost:8082/login');

        });

        document.getElementById('registerBtn').addEventListener('click', (e) => {
            e.preventDefault();
            window.location.href = '/register.html';
        });
    </script>
</body>
</html>
