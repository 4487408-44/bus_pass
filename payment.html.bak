<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Payment - Bus Pass Management</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="style.css">

    <style>
        .qr-placeholder {
            width: 150px;
            height: 150px;
            margin: 0 auto;
            background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="%232563eb" stroke-width="1.5"><path d="M3 3h8v8H3zM13 3h8v8h-8zM3 13h8v8H3zM13 13h3v3h-3zM18 13h3v3h-3zM13 18h3v3h-3zM18 18h3v3h-3z"/></svg>') no-repeat center center;
            background-size: contain;
        }
        .hidden {
            display: none;
        }
        .upi-toggle {
            padding: 0.5rem;
            border: 2px solid var(--border);
            border-radius: var(--radius);
            cursor: pointer;
            font-weight: 600;
        }
        .upi-toggle.active {
            border-color: var(--primary);
            background: rgba(37, 99, 235, 0.05);
            color: var(--primary);
        }
    </style>
</head>

<body>

<nav class="navbar">
    <div class="logo">BusPass</div>
    <div class="nav-links">
        <a href="renewal.html">Cancel / Back</a>
    </div>
</nav>

<div class="container center-layout" style="align-items: flex-start; margin-top: 2rem;">
    <div class="card wide-card" style="max-width: 600px;">

        <h2 class="card-title">Complete Payment</h2>
        <p class="card-subtitle">Pay using UPI</p>

        <!-- Amount -->
        <div style="background: var(--surface); padding: 1.5rem; border-radius: 8px; margin-bottom: 2rem; border: 1px dashed var(--border); text-align: center;">
            <p style="font-size: 0.9rem; color: var(--text-muted);">Amount to Pay</p>
            <h1 style="font-size: 2.5rem;">₹ 850</h1>
        </div>

        <form id="paymentForm" onsubmit="processPayment(event)">

            <!-- UPI Toggle -->
            <div style="display: flex; gap: 1rem; margin-bottom: 1.5rem;">
                <div class="upi-toggle active" id="upiIdTab" onclick="toggleUpi('id')">Enter UPI ID</div>
                <div class="upi-toggle" id="upiQrTab" onclick="toggleUpi('qr')">Scan QR</div>
            </div>

            <!-- UPI ID -->
            <div id="upiIdBlock">
                <div class="form-group">
                    <label>Enter UPI ID</label>
                    <input type="text" id="upiInput" class="form-control"
                        placeholder="example@upi" required>
                </div>
            </div>

            <!-- QR -->
            <div id="upiQrBlock" class="hidden" style="text-align:center;">
                <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 1rem;">
                    Scan using PhonePe / GPay / Paytm
                </p>
                <div class="qr-placeholder"></div>
            </div>

            <button type="submit" class="btn btn-primary"
                style="margin-top: 1.5rem; font-size: 1.1rem; padding: 1rem;">
                Pay ₹ 850
            </button>

        </form>
    </div>
</div>

<script>
function toggleUpi(type) {
    document.getElementById('upiIdTab').classList.remove('active');
    document.getElementById('upiQrTab').classList.remove('active');

    if (type === 'id') {
        document.getElementById('upiIdTab').classList.add('active');
        document.getElementById('upiIdBlock').classList.remove('hidden');
        document.getElementById('upiQrBlock').classList.add('hidden');
        document.getElementById('upiInput').setAttribute('required', 'true');
    } else {
        document.getElementById('upiQrTab').classList.add('active');
        document.getElementById('upiQrBlock').classList.remove('hidden');
        document.getElementById('upiIdBlock').classList.add('hidden');
        document.getElementById('upiInput').removeAttribute('required');
    }
}

function processPayment(e) {
    e.preventDefault();

    const btn = e.target.querySelector('button');
    btn.textContent = "Processing...";
    btn.disabled = true;

    setTimeout(() => {
        // redirect after payment
        window.location.href = "status.html?success=true";
    }, 1500);
}
</script>

</body>
</html>