<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Bus Pass Management</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <nav class="navbar">
        <div class="logo">
            BusPass
        </div>
        <div class="nav-links">
            <a href="login.html" onclick="logout()">Logout</a>
        </div>
    </nav>

    <div class="container">

        <!-- Monthly Banner -->
        <div id="monthlyBanner" class="card wide-card" style="display: flex; margin: 0 auto 1.5rem auto; background: linear-gradient(135deg, var(--primary), #1e40af); color: white; padding: 2rem; justify-content: space-between; align-items: center; border-radius: 16px;">
            <div>
                <span>Your Active Pass</span>
                <h2 id="mBannerTitle">Monthly Pass</h2>
                <div id="mBannerRoute">Route: N/A</div>
                <div id="mBannerEnd">Valid until: Date</div>
            </div>
            <div>
                <a href="view-pass.html?show=monthly" class="btn btn-primary" style="background: white; color: var(--primary);">View</a>
            </div>
        </div>

        <!-- Daily Banner -->
        <div id="dailyBanner" class="card wide-card" style="display: flex; margin: 0 auto 2rem auto; background: linear-gradient(135deg, #10b981, #047857); color: white; padding: 2rem; justify-content: space-between; align-items: center; border-radius: 16px;">
            <div>
                <span>Your Active Pass</span>
                <h2 id="dBannerTitle">Daily Pass</h2>
                <div id="dBannerRoute">Limit: N/A</div>
                <div id="dBannerEnd">Valid until: Date</div>
            </div>
            <div>
                <a href="view-pass.html?show=daily" class="btn btn-primary" style="background: white; color: #10b981;">View</a>
            </div>
        </div>

        <!-- Options -->
        <div class="options-grid" style="grid-template-columns: 1fr 1fr;">
            
            <a href="monthly-menu.html" class="option-card">
                <div class="option-icon">📅</div>
                <h3>Monthly Pass</h3>
                <p>Apply or renew 30-day pass</p>
            </a>

            <a href="daily-pass.html" class="option-card">
                <div class="option-icon">🎫</div>
                <h3>Daily Pass</h3>
                <p>Generate 1-day pass</p>
            </a>

        </div>

    </div>

<script>
document.addEventListener("DOMContentLoaded", async () => {

    const user_id = localStorage.getItem("user_id");

    if (!user_id) {
        alert("Please login first");
        window.location.href = "login.html";
        return;
    }

    try {
        const res = await fetch('http://localhost:8082/get_passes', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ user_id })
        });

        const data = await res.json();
        console.log("Fetched passes:", data);

        // ✅ HIDE banners if no pass (NEW)
		if (!data.passes || data.passes.length === 0) {

			// ✅ Show Monthly Banner (default message)
			document.getElementById("monthlyBanner").style.display = "flex";
			document.getElementById("mBannerTitle").innerHTML = "No Monthly Pass";
			document.getElementById("mBannerRoute").textContent = "Apply for a monthly pass";
			document.getElementById("mBannerEnd").textContent = "";

			// ✅ Show Daily Banner (default message)
			document.getElementById("dailyBanner").style.display = "flex";
			document.getElementById("dBannerTitle").innerHTML = "No Daily Pass";
			document.getElementById("dBannerRoute").textContent = "Apply for a daily pass";
			document.getElementById("dBannerEnd").textContent = "";

			return;
		}
        data.passes.forEach(p => {

            const today = new Date();
            const expiry = new Date(p.expiry_date);

            // ✅ BETTER BADGE UI (NEW)
            let status = expiry < today
                ? '<span style="background:#ef4444;color:white;padding:4px 10px;border-radius:20px;font-size:12px;">Expired</span>'
                : '<span style="background:white;color:black;padding:4px 10px;border-radius:20px;font-size:12px;">Active</span>';

            if (p.type.toLowerCase() === "daily") {

                document.getElementById("dBannerRoute").textContent = "Limit: " + p.bus;
                document.getElementById("dBannerEnd").textContent = "Valid until: " + p.expiry_date;
                document.getElementById("dBannerTitle").innerHTML = `Daily Pass ${status}`;

            } else {

                document.getElementById("mBannerRoute").textContent = "Route: " + p.bus;
                document.getElementById("mBannerEnd").textContent = "Valid until: " + p.expiry_date;
                document.getElementById("mBannerTitle").innerHTML = `${p.type} Pass ${status}`;
            }

        });

    } catch (err) {
        console.error("Error:", err);
        alert("Server error");
    }

});

function logout() {
    localStorage.clear();
}
</script>
</body>
</html>